# ─── Build-time config (read in rsbuild.config.ts via loadEnv) ───
# Dev server port for the MF remote (must be free in the portal; 3001 = auth).
APP_PORT=3020
# Public origin the federated assets are served from (publicPath). Override in prod.
APP_URL=http://localhost:3020/
# Emit external source maps on production builds.
ENABLE_SOURCE_MAP_PLUGIN=false
# Comma-separated portal shell origin(s) allowed by CORS. Unset = open (dev only);
# set to the shell origin(s) in prod, e.g. https://dev.portal.fbusinesscenter.com
SHELL_ORIGIN=

# ─── Client-exposed config (Rsbuild inlines only PUBLIC_* into the bundle) ───
# Copy to `.env.local` for local overrides (gitignored). NEVER put secrets here.
# Base URL for the customer API (axios baseURL). Defaults to /api when unset.
PUBLIC_API_BASE_URL=/api
